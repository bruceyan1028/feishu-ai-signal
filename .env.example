# ============================================================================
# 首次部署三步走：
#   1) 下面三项填你自己的：飞书自建应用 App ID / App Secret + 你自己多维表格的
#      app_token（浏览器打开你的 Base，地址里 base/ 后面那一串就是 FEISHU_BASE_ID）。
#   2) 运行  python -m src.bootstrap  —— 会在你的 Base 里自动建好全部 9 张表并写入默认配置，
#      并打印出下面各 FEISHU_*_TABLE_ID，把它们粘回本文件覆盖占位符即可。
#   3) 填好末尾的 LLM_API_KEY / LLM_BASE_URL，再运行 python -m src.main。
# ============================================================================

# 飞书自建应用凭证（必填，请勿提交真实值）
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=your_feishu_app_secret

# 你自己多维表格的 app_token（必填）。下面的 table id 先留空，
# 跑完 python -m src.bootstrap 后把打印出来的值粘进来。
FEISHU_BASE_ID=your_base_app_token
FEISHU_PARAM_TABLE_ID=
FEISHU_ENTRY_TABLE_ID=
FEISHU_BRIEF_TABLE_ID=
# 信号源表（bootstrap 会自动创建并写入母版清单）
FEISHU_SOURCE_TABLE_ID=

# 类型化筛选配置表（bootstrap 会自动创建；一源一行，主键 source_id）
FEISHU_PAPER_CONFIG_TABLE_ID=
FEISHU_WECHAT_CONFIG_TABLE_ID=
FEISHU_VIDEO_CONFIG_TABLE_ID=
FEISHU_SOCIAL_CONFIG_TABLE_ID=
FEISHU_GITHUB_CONFIG_TABLE_ID=

# 飞书机器人卡片（多个 open_id 用英文逗号分隔；单人变量保留兼容）
FEISHU_RECIPIENT_OPEN_IDS=ou_xxxxxxxxxxxx,ou_yyyyyyyyyyyy
FEISHU_RECIPIENT_OPEN_ID=
PUBLIC_BASE_URL=https://your-account.github.io/feishu-ai-signal

# 可选：Jina Reader（Scrape 源诊断 / 抓取）
JINA_API_KEY=

# 可选：Dify Webhook（留空则跳过）
DIFY_WEBHOOK_URL=

# LLM 分析（OpenAI 兼容接口，可指向 DeepSeek / 通义 / OpenAI 等）
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 每日简报规模
DAILY_CANDIDATE_LIMIT=30
DAILY_SIGNAL_LIMIT=30
# 每份简报里「论文」类条目的硬上限
DAILY_MAX_PAPERS=4

# 论文过滤
MAX_ARXIV_ITEMS=10
ARXIV_MIN_SIGNAL_SCORE=55
# arXiv 在简报排序里的质量权重（<1 降权），有限的论文名额优先给 hf/pwc/已录用
ARXIV_QUALITY_WEIGHT=0.7
PAPER_QUALITY_MIN_SCORE=60
# arXiv 预印本必须有社区热度（HF upvotes）才保留，已录用会议/顶刊豁免；设 0 可关闭
ARXIV_REQUIRE_COMMUNITY_HEAT=1
PAPER_ENRICH_TIMEOUT=12
PAPER_ENRICH_ENABLED=1

# Scrape 源单源最多抓取的文章数
DEFAULT_MAX_ARTICLES=8
