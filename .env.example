# 飞书应用凭证（必填，请勿提交真实值）
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=your_feishu_app_secret

# 多维表配置（前三项有默认值；每日简报表留空时自动创建）
FEISHU_BASE_ID=RuI1b05wHa8bIUsok0ac35S8nAd
FEISHU_PARAM_TABLE_ID=tblnJ0vumx8ITmlU
FEISHU_ENTRY_TABLE_ID=tblgeB5ArAD1ugoi
FEISHU_BRIEF_TABLE_ID=

# 飞书机器人卡片（多个 open_id 用英文逗号分隔；单人变量保留兼容）
FEISHU_RECIPIENT_OPEN_IDS=ou_xxxxxxxxxxxx,ou_yyyyyyyyyyyy
FEISHU_RECIPIENT_OPEN_ID=
PUBLIC_BASE_URL=https://your-account.github.io/feishu-ai-signal

# 可选：Jina Reader（Scrape 源诊断 / 抓取）
JINA_API_KEY=

# 可选：Dify Webhook（留空则跳过）
DIFY_WEBHOOK_URL=

# LLM 分析（OpenAI 兼容接口，可指向 DeepSeek / 通义 / OpenAI 等）
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 每日简报规模
DAILY_CANDIDATE_LIMIT=30
DAILY_SIGNAL_LIMIT=30
MAX_ARXIV_ITEMS=10
ARXIV_MIN_SIGNAL_SCORE=55
PAPER_QUALITY_MIN_SCORE=45
PAPER_ENRICH_TIMEOUT=12
PAPER_ENRICH_ENABLED=1
